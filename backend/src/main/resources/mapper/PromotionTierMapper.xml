<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.mapper.PromotionTierMapper">
    <resultMap id="BaseResultMap" type="com.shop.entity.PromotionTier">
        <id column="id" property="id"/>
        <result column="promotion_id" property="promotionId"/>
        <result column="threshold" property="threshold"/>
        <result column="discount" property="discount"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.shop.entity.PromotionTier" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO promotion_tier (promotion_id, threshold, discount, sort_order)
        VALUES (#{promotionId}, #{threshold}, #{discount}, #{sortOrder})
    </insert>

    <select id="selectByPromotionId" resultMap="BaseResultMap">
        SELECT * FROM promotion_tier
        WHERE promotion_id = #{promotionId}
        ORDER BY sort_order ASC, threshold ASC
    </select>

    <delete id="deleteByPromotionId">
        DELETE FROM promotion_tier WHERE promotion_id = #{promotionId}
    </delete>
</mapper>
